# LecGraph Configuration

# OpenAI API Key (required for knowledge extraction)
OPENAI_API_KEY=your-openai-api-key

# Whisper Configuration
WHISPER_MODEL_SIZE=large-v3
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=float16

# Embedding Model
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# Segmentation
SEGMENT_MIN_DURATION=30
SEGMENT_MAX_DURATION=1200
SIMILARITY_SMOOTHING_WINDOW=3

# LLM
LLM_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=4096
LLM_MAX_WORKERS=5

# Neo4j (used by docker-compose)
NEO4J_PASSWORD=lecgraph123

# Output
OUTPUT_DIR=output
